{
  "manifest_version": 2,

  "browser_specific_settings": {
    "gecko": {
      "id": "marble-olounge@mozilla.org"
    }
  },

  "name": "Orange Lounge",
  "description": "A bright appearance for your browser, based on TOMOSUKE's fictional lounge duo.",
  "version": "1.0",
  "icons": { "32": "icon.svg" },

  "theme": {
    "images": {
      "additional_backgrounds": [
        "lounge_light.png"
      ]
    },

    "properties": {
      "additional_backgrounds_alignment": [
        "left top"
      ],
      "additional_backgrounds_tiling": ["repeat"],
      "zap_gradient": "linear-gradient(90deg, #f59464 0%, #f4ba2f 100%)"
    },
    "colors": {
      "frame": "rgba(255, 204, 170, 0.72)",
      "toolbar": "rgba(255, 204, 170, 0.72)",
      "button_background_active": "hsla(27, 68%, 57.1%, 0.6)",
      "button_background_hover": "hsla(27, 68%, 34%, 0.4)",
      "icons": "rgb(128, 51, 0)",
      "icons_attention": "hsla(24, 100%, 32%, 1)",
      "toolbar_text": "hsla(24, 100%, 25%, 1)",
      "toolbar_vertical_separator": "hsla(261, 53%, 15%, .2)",
      "toolbar_field": "hsla(0, 0%, 100%, .8)",
      "toolbar_field_focus": "rgb(255, 247, 239)",
      "toolbar_field_text": "rgb(59, 41, 18)",
      "toolbar_field_text_focus": "rgb(59, 41, 18)",
      "toolbar_field_border": "rgba(172, 125, 76, 0.75)",
      "toolbar_field_border_focus": "rgb(223, 200, 170)",
      "toolbar_field_highlight": "hsla(265, 100%, 72%, .32)",
      "toolbar_top_separator": "rgba(0, 0, 0, 0.3)",
      "toolbar_bottom_separator": "hsla(261, 53%, 15%, .32)",
      "bookmark_text": "hsla(261, 53%, 15%, 1)",
      "tab_text": "hsla(24, 100%, 25%, 1)",
      "tab_background_text": "hsla(24, 100%, 25%, 1)",
      "tab_background_separator": "hsla(261, 53%, 15%, 1)",
      "tab_line": "rgb(212, 85, 0)",
      "tab_loading": "rgb(147, 163, 202)",
      "ntp_background": "#F9F9FB",
      "ntp_text": "hsla(261, 53%, 15%, 1)",
      "popup": "rgb(255, 248, 241)",
      "popup_text": "rgb(70, 66, 64)",
      "popup_border": "rgba(117, 135, 136, 0.32)",
      "popup_highlight": "rgba(255, 131, 0, 0.12)",
      "popup_highlight_text": "rgb(145, 75, 0)",
      "sidebar": "rgb(255, 249, 244)",
      "sidebar_text": "hsla(261, 53%, 15%, 1)",
      "sidebar_border": "hsla(261, 53%, 15%, .24)",
      "sidebar_highlight": "rgb(213, 153, 89)",
      "sidebar_highlight_text": "hsla(0, 0%, 100%, 1)",
      "focus_outline": "hsla(24, 100%, 42%, 1)"
    }
  },
  "dark_theme": {
    "images": {
      "additional_backgrounds": [
        "lounge_dark.png"
      ]
    },

    "properties": {
      "color_scheme": "dark",
      "additional_backgrounds_alignment": [
        "right top"
      ],
      "additional_backgrounds_tiling": ["repeat"],
      "zap_gradient": "linear-gradient(90deg, #f59464 0%, #f4ba2f 100%)"
    },
    "colors": {
      "frame": "rgba(106, 52, 16, 0.72)",
      "toolbar": "rgba(106, 52, 16, 0.72)",
      "button_background_active": "hsla(255, 100%, 94%, .24)",
      "button_background_hover": "hsla(255, 100%, 94%, .12)",
      "icons": "rgb(206, 182, 151)",
      "icons_attention": "hsla(157, 100%, 66%, 1)",
      "toolbar_text": "rgb(251, 236, 225)",
      "toolbar_vertical_separator": "hsla(271, 100%, 77%, .4)",
      "toolbar_field": "rgb(64, 41, 21)",
      "toolbar_field_focus": "rgba(51, 37, 27, 0.98)",
      "toolbar_field_text": "rgb(255, 236, 219)",
      "toolbar_field_text_focus": "rgb(255, 240, 224)",
      "toolbar_field_border": "rgba(119, 95, 81, 0.33)",
      "toolbar_field_border_focus": "rgb(164, 113, 82)",
      "toolbar_field_highlight": "rgba(255, 166, 112, 0.32)",
      "toolbar_top_separator": "rgba(77, 49, 19, 0.96)",
      "toolbar_bottom_separator": "rgba(149, 104, 71, 0.96)",
      "bookmark_text": "hsla(255, 100%, 94%, 1)",
      "tab_selected": "rgba(79, 65, 56, 0.82)",
      "tab_text": "rgb(255, 255, 255)",
      "tab_background_text": "rgb(227, 242, 221)",
      "tab_background_separator": "rgb(155, 62, 0)",
      "tab_line": "rgb(155, 62, 0)",
      "tab_loading": "rgb(138, 101, 69)",
      "ntp_background": "#2A2A2E",
      "ntp_text": "rgb(240, 214, 186)",
      "popup": "rgb(64, 41, 21)",
      "popup_text": "rgb(255, 234, 224)",
      "popup_border": "rgba(176, 113, 76, 0.32)",
      "popup_highlight": "hsla(255, 100%, 94%, .12)",
      "popup_highlight_text": "hsla(0, 0%, 100%, 1)",
      "sidebar": "rgb(91, 42, 15)",
      "sidebar_text": "rgb(255, 255, 255)",
      "sidebar_border": "hsla(255, 100%, 94%, .24)",
      "sidebar_highlight": "rgb(255, 166, 112)",
      "sidebar_highlight_text": "rgb(255, 255, 255)",
      "focus_outline": "rgb(34, 121, 64)"
    }
  },

  "theme_experiment": {
    "colors": {
      "focus_outline": "--focus-outline-color"
    },
    "properties": {
      "zap_gradient": "--panel-separator-zap-gradient"
    }
  }
}
